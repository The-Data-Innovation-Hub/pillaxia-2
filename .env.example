# Supabase (optional / deprecated – app uses Azure only; leave unset to disable Supabase client)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_PROJECT_ID=

# Optional
VITE_ENABLE_DEMO=false
VITE_VAPID_PUBLIC_KEY=

# Multi-tenant mode: when true, org switcher is shown in admin sidebar (when user has multiple orgs)
# and non-admins see "No organization assigned" instead of "single-tenant mode" on Organization page
# VITE_MULTI_TENANT=true

# ---------------------------------------------------------------------------
# Azure / Entra ID (required for sign-in, /api/me, and token exchange)
# ---------------------------------------------------------------------------
# App registration (Client) ID from Azure Portal → Microsoft Entra ID → App registrations
VITE_ENTRA_CLIENT_ID=

# Directory (tenant) ID from the same app registration
VITE_ENTRA_TENANT_ID=

# Authority URL. Single-tenant: https://login.microsoftonline.com/{VITE_ENTRA_TENANT_ID}/
# Multi-tenant: https://login.microsoftonline.com/common/
VITE_ENTRA_EXTERNAL_ID_AUTHORITY=

# Redirect URI registered in the app registration.
# Web: your app origin + /auth/callback (e.g. http://localhost:5173/auth/callback for local, https://your-app.azurestaticapps.net/auth/callback for prod)
# Native (Capacitor): capacitor://localhost
VITE_ENTRA_REDIRECT_URI=http://localhost:5173/auth/callback

# Azure API / Functions base URL (no trailing slash). Used for:
# - GET /api/me (profile and roles)
# - POST /api/auth-exchange-native (code-for-token exchange on native)
# - All REST and invoke calls (data layer, offline queue replay, Angela/CDS, get-vapid-public-key, etc.)
# Prefer VITE_API_URL; falls back to VITE_AZURE_FUNCTIONS_URL
VITE_API_URL=
VITE_AZURE_FUNCTIONS_URL=

# Optional overrides (code falls back to VITE_ENTRA_* above)
# VITE_AZURE_AUTHORITY=
# VITE_AZURE_CLIENT_ID=
# VITE_AZURE_REDIRECT_URI=
# VITE_ENTRA_SCOPES=openid,profile,email
